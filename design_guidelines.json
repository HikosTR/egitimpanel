      "course_strategy": "https://images.unsplash.com/photo-1765438864799-6e620d420a6d?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAxODF8MHwxfHNlYXJjaHwxfHxidXNpbmVzcyUyMHN0cmF0ZWd5JTIwcHJlc2VudGF0aW9uJTIwbWFya2V0aW5nJTIwY2hhcnR8ZW58MHx8fHwxNzcxMTkzMjk2fDA&ixlib=rb-4.1.0&q=85",
      "course_marketing": "https://images.unsplash.com/photo-1758691736542-c437fea2c673?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAxODF8MHwxfHNlYXJjaHw0fHxidXNpbmVzcyUyMHN0cmF0ZWd5JTIwcHJlc2VudGF0aW9uJTIwbWFya2V0aW5nJTIwY2hhcnR8ZW58MHx8fHwxNzcxMTkzMjk2fDA&ixlib=rb-4.1.0&q=85",
      "avatar_male": "https://images.unsplash.com/photo-1769636929261-e913ed023c83?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2Njd8MHwxfHNlYXJjaHwzfHxwcm9mZXNzaW9uYWwlMjBjb3Jwb3JhdGUlMjBoZWFkc2hvdCUyMHBvcnRyYWl0fGVufDB8fHx8MTc3MTE5MzI5N3ww&ixlib=rb-4.1.0&q=85",
      "avatar_female": "https://images.unsplash.com/photo-1758599543120-4e462429a4d7?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2Njd8MHwxfHNlYXJjaHw0fHxwcm9mZXNzaW9uYWwlMjBjb3Jwb3JhdGUlMjBoZWFkc2hvdCUyMHBvcnRyYWl0fGVufDB8fHx8MTc3MTE5MzI5N3ww&ixlib=rb-4.1.0&q=85",
      "badge_gold": "https://images.unsplash.com/photo-1671739250895-1d57d6095a05?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA0MTJ8MHwxfHNlYXJjaHwzfHxnb2xkJTIwYWNoaWV2ZW1lbnQlMjBtZWRhbCUyMGJhZGdlJTIwc2ltcGxlfGVufDB8fHx8MTc3MTE5MzI5OHww&ixlib=rb-4.1.0&q=85",
      "logo_placeholder": "https://images.unsplash.com/photo-1756999223507-72bfbb654193?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NzF8MHwxfHNlYXJjaHwxfHxtaW5pbWFsaXN0JTIwZ3JlZW4lMjBhYnN0cmFjdCUyMGxvZ298ZW58MHx8fHwxNzcxMTkzMjk5fDA&ixlib=rb-4.1.0&q=85"
    },
    "icons_library": "lucide-react"
  },
  "instructions_to_main_agent": [
    "IMPORTANT: YOU HAVE .JS FILES. Convert all design logic to plain React/JS. Do not use TS types.",
    "Implement the 'Locked Progression' visual state using greyed-out cards with a lock icon overlay.",
    "Use 'Barlow Condensed' for all headings to give that 'Strong Leadership' vibe.",
    "The Sidebar MUST be dark (#111111) with white text. The main content area MUST be light/white.",
    "Use the primary green (#00C853) sparingly for CTAs, Progress Bars, and Active States to maintain high impact.",
    "Login Page: Split screen. Left side: Dark area with 'Motivation Text' and Image Overlay. Right side: Clean white form.",
    "Certificates: Use a clean border layout with the Logo and Gold Badge image centered.",
    "Use Recharts for the Analytics dashboard (Bar charts for user progress, Pie charts for course completion).",
    "Ensure all text is Turkish language as per requirements.",
    "For the 'Level System', create a visual hierarchy (e.g., Bronze, Silver, Gold, Elite) using badge icons and color coding in the Profile section.",
    "All interactive elements MUST have 'data-testid' attributes."
  ],
  "UNIVERSAL_GUIDELINES": [
    "Do not use gradients for dark colors.",
    "Use 2-3x more spacing than feels comfortable.",
    "Add micro-interactions: hover states, transitions.",
    "Use 'sonner' for toasts.",
    "Components must use named exports.",
    "Pages must use default exports.",
    "Never use AI emoji icons."
  ]
}