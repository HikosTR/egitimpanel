{
  "project_name": "ProFit Team - Eğitim Platformu",
  "design_philosophy": {
    "theme": "Corporate Leadership",
    "tone": "Strong, Elite, Disciplined, Professional",
    "core_concept": "Progress through Discipline",
    "visual_style": "High Contrast, Minimalist, Data-Driven"
  },
  "typography": {
    "font_family": {
      "headings": "Barlow Condensed, sans-serif",
      "body": "Manrope, sans-serif"
    },
    "scale": {
      "h1": "text-5xl font-bold tracking-tight uppercase",
      "h2": "text-3xl font-bold tracking-tight uppercase",
      "h3": "text-2xl font-semibold tracking-normal",
      "body": "text-base font-normal leading-relaxed",
      "caption": "text-sm font-medium text-muted-foreground uppercase tracking-wider"
    },
    "imports": [
      "@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Manrope:wght@400;500;600;700&display=swap');"
    ]
  },
  "colors": {
    "palette": {
      "background": "#FFFFFF",
      "foreground": "#111111",
      "card": "#FFFFFF",
      "card_foreground": "#111111",
      "primary": "#00C853",
      "primary_foreground": "#FFFFFF",
      "secondary": "#F5F7FA",
      "secondary_foreground": "#111111",
      "muted": "#F5F7FA",
      "muted_foreground": "#64748B",
      "destructive": "#EF4444",
      "destructive_foreground": "#FFFFFF",
      "border": "#E2E8F0",
      "input": "#E2E8F0",
      "ring": "#00C853",
      "sidebar": "#111111",
      "sidebar_foreground": "#FFFFFF",
      "sidebar_hover": "#222222",
      "success": "#00C853",
      "warning": "#F59E0B"
    },
    "gradients": {
      "primary_action": "bg-gradient-to-r from-[#00C853] to-[#00E676]",
      "dark_surface": "bg-gradient-to-b from-[#111111] to-[#0A0A0A]"
    }
  },
  "layout": {
    "spacing": {
      "container_padding": "p-6 md:p-8 lg:p-12",
      "section_gap": "gap-8",
      "card_padding": "p-6"
    },
    "radius": {
      "default": "rounded-lg",
      "card": "rounded-lg",
      "button": "rounded-md"
    },
    "grid_system": {
      "dashboard": "grid grid-cols-1 md:grid-cols-12 gap-6",
      "bento_metrics": "col-span-12 md:col-span-3 h-32",
      "bento_main_chart": "col-span-12 md:col-span-8 row-span-2",
      "bento_side_list": "col-span-12 md:col-span-4 row-span-2"
    }
  },
  "components": {
    "buttons": {
      "primary": "bg-primary text-primary-foreground hover:bg-green-600 shadow-md transition-all duration-200 uppercase font-bold tracking-wide",
      "secondary": "bg-secondary text-secondary-foreground hover:bg-gray-200 uppercase font-semibold tracking-wide",
      "outline": "border-2 border-primary text-primary hover:bg-primary hover:text-white uppercase font-bold tracking-wide"
    },
    "cards": {
      "default": "bg-white border border-border shadow-sm hover:shadow-md transition-shadow duration-300",
      "metric": "bg-white border-l-4 border-l-primary shadow-sm"
    },
    "inputs": {
      "default": "bg-white border-input focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 rounded-md"
    },
    "sidebar": {
      "container": "bg-[#111111] text-white h-screen w-64 flex flex-col fixed left-0 top-0 z-50",
      "item": "flex items-center gap-3 px-4 py-3 text-gray-400 hover:text-white hover:bg-[#222222] transition-colors duration-200 rounded-lg mx-2 my-1",
      "item_active": "bg-primary text-white font-semibold"
    }
  },
  "visual_enhancers": {
    "shadows": {
      "card": "shadow-[0_2px_8px_rgba(0,0,0,0.05)]",
      "hover": "shadow-[0_8px_24px_rgba(0,0,0,0.12)]",
      "glow": "shadow-[0_0_15px_rgba(0,200,83,0.3)]"
    },
    "borders": {
      "subtle": "border border-gray-100",
      "highlight": "border-l-4 border-primary"
    }
  },
  "assets": {
    "images": {
